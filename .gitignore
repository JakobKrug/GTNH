# Ignore everything in the instance folder
/*
# Nesting Level 0
!/.minecraft/
/.minecraft/*
!/.gitignore
!/conflict.bat
!/conflict.sh
!/post_game.bat
!/post_game.sh
!/README.md

# Nesting Level 1
!/.minecraft/blueprints/

!/.minecraft/config/
/.minecraft/config/*
!/.minecraft/config/dsurround/
/.minecraft/config/dsurround/*
!/.minecraft/config/dsurround/dsurround.cfg
!/.minecraft/config/Waila.cfg
!/.minecraft/config/WailaHarvestability.cfg
!/.minecraft/config/lwjgl3ify.cfg

!/.minecraft/journeymap/

!/.minecraft/mods/
/.minecraft/mods/*
!/.minecraft/mods/deconfigintegration-1.0.1.jar
!/.minecraft/mods/goverlays-1.1.2.jar

!/.minecraft/resourcepacks/
!/.minecraft/saves/
!/.minecraft/saves/NEI/
!/.minecraft/schematics/
!/.minecraft/screenshots/
!/.minecraft/shaderpacks/
!/.minecraft/TCNodeTracker/
!/.minecraft/texturepacks/
!/.minecraft/visualprospecting/

*.log
*.tmp
.minecraft/journeymap/icon/